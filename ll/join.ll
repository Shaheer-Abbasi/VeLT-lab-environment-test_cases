@.str.5 = private unnamed_addr constant [136 x i8] c"  -a FILENUM\0A         also print unpairable lines from file FILENUM,\0A         where FILENUM is 1 or 2, corresponding to FILE1 or FILE2\0A\00", align 1
@.str.6 = private unnamed_addr constant [133 x i8] c"  -e STRING\0A         replace missing (empty) input fields with STRING;\0A         I.e., missing fields specified with '-12jo' options\0A\00", align 1
@.str.7 = private unnamed_addr constant [79 x i8] c"  -i, --ignore-case\0A         ignore differences in case when comparing fields\0A\00", align 1
@.str.8 = private unnamed_addr constant [55 x i8] c"  -j FIELD\0A         equivalent to '-1 FIELD -2 FIELD'\0A\00", align 1
@.str.9 = private unnamed_addr constant [65 x i8] c"  -o FORMAT\0A         obey FORMAT while constructing output line\0A\00", align 1
@.str.10 = private unnamed_addr constant [65 x i8] c"  -t CHAR\0A         use CHAR as input and output field separator\0A\00", align 1
@.str.11 = private unnamed_addr constant [73 x i8] c"  -v FILENUM\0A         like -a FILENUM, but suppress joined output lines\0A\00", align 1
@.str.12 = private unnamed_addr constant [50 x i8] c"  -1 FIELD\0A         join on this FIELD of file 1\0A\00", align 1
@.str.13 = private unnamed_addr constant [50 x i8] c"  -2 FIELD\0A         join on this FIELD of file 2\0A\00", align 1
@.str.14 = private unnamed_addr constant [118 x i8] c"      --check-order\0A         check that the input is correctly sorted, even\0A         if all input lines are pairable\0A\00", align 1
